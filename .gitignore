.env.dev
.env.prod
__pycache__/
*.egg-info/
dist/
build/
.venv/
node_modules/

# Third-party skills (managed via skills-lock.json, not source)
.agents/
.claude/
.pi/

# Wrangler local cache
.wrangler/

# Studio: MLflow tracking stores and temp plot output
studio/templates/*/mlruns/
studio/templates/*/_tmp_plots/
studio/scratch/*/mlruns/
studio/scratch/*/_tmp_plots/

# Marimo internal session cache
**/__marimo__/

# Runtime logs and LLM venv
logs/
.venv-llm/

# MLflow runtime tracking store
mlflow.db
mlruns/

# Unsloth's torch.compile cache
unsloth_compiled_cache/

# NHTSA flat file (1.5 GB) — downloaded/cached at runtime
# Keep CMPL_SCHEMA.txt (small, indispensable for agents)
bundles/llm-finetuning/nhtsa_cache/FLAT_CMPL.txt
